# Database
DATABASE_URL=sqlite+aiosqlite:///./fastapi.db

# JWT
JWT_SECRET=your-secret-key

# Google Service Account Credentials
GOOGLE_APPLICATION_CREDENTIALS_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_APPLICATION_CREDENTIALS_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_APPLICATION_CREDENTIALS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS_CLIENT_ID=your-client-id
GOOGLE_APPLICATION_CREDENTIALS_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_APPLICATION_CREDENTIALS_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_APPLICATION_CREDENTIALS_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_APPLICATION_CREDENTIALS_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account

# Your personal email for access
USER_EMAIL=your-personal-email@gmail.com